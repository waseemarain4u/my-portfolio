---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage: string;
  tag: string;
  date: string;
  readTime: string;
  mediumUrl?: string;
}
const { title, description, canonicalUrl, ogImage, tag, date, readTime, mediumUrl } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${title} — Waseem Akram`} description={description} canonicalUrl={canonicalUrl} ogImage={ogImage} ogType="article" page="article">
  <main class="pt-24">
    <section class="pt-12 pb-8 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-80 h-80 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="max-w-3xl mx-auto px-6 relative z-10">
        <a href={`${base}blog`} class="inline-flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400 hover:text-accent transition-colors mb-8">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          All articles
        </a>
        <div class="flex items-center gap-3 mb-5">
          <span class="text-xs bg-blue-50 dark:bg-zinc-800 text-accent border border-blue-200 dark:border-zinc-700 px-2.5 py-1 rounded-full">{tag}</span>
          <span class="text-xs text-zinc-400">{date} · {readTime}</span>
          {mediumUrl && (
            <a href={mediumUrl} target="_blank" rel="noopener" class="text-xs text-zinc-400 hover:text-accent transition-colors flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              Originally on Medium
            </a>
          )}
        </div>
        <h1 class="font-display font-bold text-4xl md:text-5xl text-zinc-900 dark:text-white mb-5 leading-tight">{title}</h1>
        <p class="text-lg text-zinc-500 dark:text-zinc-400 leading-relaxed mb-8">{description}</p>
        <div class="flex items-center gap-3 pb-8 border-b border-zinc-100 dark:border-zinc-800">
          <div class="w-10 h-10 rounded-full bg-accent flex items-center justify-center text-white font-bold text-sm shrink-0">WA</div>
          <div>
            <p class="text-sm font-medium text-zinc-900 dark:text-white">Waseem Akram</p>
            <p class="text-xs text-zinc-500">Senior Flutter Developer &amp; Lead Developer</p>
          </div>
        </div>
      </div>
    </section>

    <div class="max-w-4xl mx-auto px-6 mb-12">
      <div class="pf w-full rounded-2xl overflow-hidden" style="height:420px">
        <img src={ogImage} alt={title} loading="eager">
      </div>
    </div>

    <article class="max-w-3xl mx-auto px-6 pb-24 prose">
      <slot />
    </article>

    <slot name="more-articles" />
  </main>
</BaseLayout>
