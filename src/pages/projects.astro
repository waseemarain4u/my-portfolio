---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Projects — Waseem Akram"
  description="15+ apps shipped across Android, Flutter, and cross-platform — from e-commerce ecosystems to AI tools and enterprise HRMS."
  canonicalUrl="https://waseemarain4u.github.io/my-portfolio/projects"
  ogImage="https://images.unsplash.com/photo-1563986768494-4dee2763ff3f?w=1200&q=80"
  page="projects"
>
  <div x-data="projects()">
    <main>
      <section class="pt-20 pb-12 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-80 h-80 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="max-w-6xl mx-auto px-6 relative z-10">
          <p class="text-xs font-medium text-accent tracking-widest uppercase mb-3">Portfolio</p>
          <h1 class="font-display font-bold text-5xl md:text-6xl text-zinc-900 dark:text-white leading-tight mb-4">All Projects</h1>
          <p class="text-lg text-zinc-500 dark:text-zinc-400 max-w-xl leading-relaxed mb-8">15+ apps shipped across Android, Flutter, and cross-platform — from e-commerce ecosystems to AI tools and enterprise HRMS.</p>
          <div class="flex flex-wrap gap-2">
            <template x-for="f in filterOptions" :key="f.value">
              <button
                @click="filter = f.value"
                :class="filter === f.value ? 'bg-accent text-white border-accent' : 'bg-white dark:bg-zinc-900 text-zinc-600 dark:text-zinc-400 border-zinc-200 dark:border-zinc-700 hover:border-accent'"
                class="text-sm px-4 py-1.5 rounded-full border transition-colors"
                x-text="f.label">
              </button>
            </template>
          </div>
        </div>
      </section>

      <section class="pb-24">
        <div class="max-w-6xl mx-auto px-6">
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            <template x-for="p in allProjects" :key="p.id">
              <div x-show="filter === 'all' || p.category === filter">
                <article class="group h-full rounded-2xl overflow-hidden bg-white dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors">
                  <div class="pf w-full h-52">
                    <img :src="p.img" :alt="p.title" loading="lazy"/>
                  </div>
                  <div class="p-6">
                    <div class="flex flex-wrap gap-2 mb-3">
                      <template x-for="tag in p.tags" :key="tag">
                        <span class="text-xs px-2.5 py-1 rounded-full"
                          :class="tag === p.categoryLabel ? 'bg-blue-50 dark:bg-zinc-800 text-accent border border-blue-200 dark:border-zinc-700' : 'bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400'"
                          x-text="tag"></span>
                      </template>
                    </div>
                    <h3 class="font-display font-bold text-lg text-zinc-900 dark:text-white mb-2" x-text="p.title"></h3>
                    <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4" x-text="p.desc"></p>
                  </div>
                </article>
              </div>
            </template>
          </div>
          <div x-show="visibleCount === 0" x-cloak class="text-center py-20">
            <p class="text-zinc-400 text-sm">No projects in this category.</p>
          </div>
        </div>
      </section>

      <section class="pb-24">
        <div class="max-w-6xl mx-auto px-6">
          <div class="bg-zinc-100 dark:bg-zinc-900 rounded-3xl p-10 md:p-14 text-center relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/20 rounded-full blur-3xl pointer-events-none"></div>
            <div class="absolute bottom-0 left-0 w-40 h-40 bg-accent/10 rounded-full blur-2xl pointer-events-none"></div>
            <div class="relative z-10">
              <p class="text-xs font-medium text-accent tracking-widest uppercase mb-4">Ready to start?</p>
              <h2 class="font-display font-bold text-3xl md:text-4xl text-zinc-900 dark:text-white mb-4">Want your app built right?</h2>
              <p class="text-zinc-500 dark:text-zinc-400 max-w-md mx-auto mb-8">I'm available for new Flutter and Android projects. Tell me what you're building and let's see how I can help.</p>
              <a href={`${base}#contact`} class="inline-flex items-center gap-2 bg-accent text-white font-medium px-8 py-3.5 rounded-full hover:bg-accent-light transition-colors">Start a project &rarr;</a>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script is:inline>
    function projects() {
      return {
        filter: 'all',
        filterOptions: [
          { value: 'all',       label: 'All (16)' },
          { value: 'flutter',   label: 'Flutter' },
          { value: 'android',   label: 'Android' },
          { value: 'enterprise',label: 'Enterprise' },
          { value: 'ecommerce', label: 'E-commerce' },
        ],
        allProjects: [
          { id:1,  title:'AI Content Master',         category:'flutter',    categoryLabel:'Flutter',    tags:['Flutter','AI','Cross-platform'],         desc:'AI-powered content generation app with rich text editing, cloud sync, and a seamless multi-platform experience.',           img:'https://images.unsplash.com/photo-1563986768494-4dee2763ff3f?w=700&q=80' },
          { id:2,  title:'One Access Portal',         category:'flutter',    categoryLabel:'Flutter',    tags:['Flutter','Portal'],                      desc:'Unified access portal delivering a single sign-on experience across multiple enterprise services.',                      img:'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=700&q=80' },
          { id:3,  title:'Trade Your Container',      category:'flutter',    categoryLabel:'Flutter',    tags:['Flutter','Logistics'],                   desc:'Cross-platform logistics marketplace for container trading with real-time listings and negotiation flows.',            img:'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=700&q=80' },
          { id:4,  title:'GetVPN',                    category:'flutter',    categoryLabel:'Flutter',    tags:['Flutter','Security'],                    desc:'Cross-platform VPN client focused on performance and a one-tap connection experience on Android and iOS.',            img:'https://images.unsplash.com/photo-1512428559087-560fa5ceab42?w=700&q=80' },
          { id:5,  title:'Humwell',                   category:'flutter',    categoryLabel:'Flutter',    tags:['Flutter','Health','Dual Language'],       desc:'Dual-language health and wellness app serving users in English and Urdu with guided care journeys.',                img:'https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=700&q=80' },
          { id:6,  title:'ClientConnect+',            category:'enterprise', categoryLabel:'Enterprise', tags:['Enterprise','Flutter','CRM'],            desc:'CRM mobile app for managing client relationships, follow-ups, and deal pipelines on the go.',                       img:'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=700&q=80' },
          { id:7,  title:'Gab — BOT',                 category:'flutter',    categoryLabel:'Flutter',    tags:['Flutter','AI','Chatbot'],                desc:'Conversational AI chatbot application with natural language processing and contextual memory.',                     img:'https://images.unsplash.com/photo-1531746790731-6c087fecd65a?w=700&q=80' },
          { id:8,  title:'OneGo — PDF Converter',     category:'flutter',    categoryLabel:'Flutter',    tags:['Flutter','Productivity'],                desc:'File conversion utility app supporting PDF, Word, and image formats with a clean, drag-and-drop interface.',         img:'https://images.unsplash.com/photo-1618401479427-c8ef9465fbe1?w=700&q=80' },
          { id:9,  title:'SKS HRMS',                  category:'enterprise', categoryLabel:'Enterprise', tags:['Enterprise','Android','HRMS'],           desc:'HR management system for enterprise clients — covering attendance, payroll, and employee lifecycle management.',      img:'https://images.unsplash.com/photo-1497366216548-37526070297c?w=700&q=80' },
          { id:10, title:'Volt Gaming',               category:'android',    categoryLabel:'Android',    tags:['Android','Gaming'],                      desc:'Mobile gaming companion app with live stats, tournament brackets, and team communication features.',               img:'https://images.unsplash.com/photo-1538481199705-c710c4e965fc?w=700&q=80' },
          { id:11, title:'Sindh Flood Relief',        category:'android',    categoryLabel:'Android',    tags:['Android','Social'],                      desc:'Emergency relief coordination app connecting volunteers, donors, and affected communities during the 2022 floods.',  img:'https://images.unsplash.com/photo-1561484930-974b10b1a400?w=700&q=80' },
          { id:12, title:'Track & Traxe',             category:'android',    categoryLabel:'Android',    tags:['Android','Tracking','GPS'],              desc:'Real-time GPS tracking app for fleet management with geofencing alerts and route history.',                          img:'https://images.unsplash.com/photo-1601972599720-36938d4ecd31?w=700&q=80' },
          { id:13, title:'My Optix',                  category:'android',    categoryLabel:'Android',    tags:['Android','Healthcare'],                  desc:'Optician and eyewear management app for prescription tracking, appointment booking, and order history.',             img:'https://images.unsplash.com/photo-1574169208507-84376144848b?w=700&q=80' },
          { id:14, title:'My Water — Customer',       category:'android',    categoryLabel:'Android',    tags:['Android','Utility'],                     desc:'Customer-facing utility app for water service billing, consumption tracking, and maintenance requests.',           img:'https://images.unsplash.com/photo-1548438294-1ad5d5f4f063?w=700&q=80' },
          { id:15, title:'MyCart — E-commerce Suite', category:'ecommerce',  categoryLabel:'E-commerce', tags:['E-commerce','Android','Multi-app'],      desc:'Full e-commerce ecosystem: consumer app, inventory management, rider app, and employee portals — all in Android.',   img:'https://images.unsplash.com/photo-1601784551446-20c9e07cdbdb?w=700&q=80' },
          { id:16, title:'My Water — Technician',     category:'android',    categoryLabel:'Android',    tags:['Android','Utility','Field Service'],     desc:'Field technician app for water service operations — job assignment, on-site status updates, and service history management.', img:'https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=700&q=80' },
        ],
        get visibleCount() {
          if (this.filter === 'all') return this.allProjects.length;
          return this.allProjects.filter(p => p.category === this.filter).length;
        }
      }
    }
  </script>
</BaseLayout>
