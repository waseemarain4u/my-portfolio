---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404 — Page Not Found" description="This page doesn't exist." page="article">
  <main class="pt-24 min-h-screen flex items-center justify-center">
    <div class="text-center px-6">
      <p class="text-xs font-medium text-accent tracking-widest uppercase mb-4">404</p>
      <h1 class="font-display font-bold text-5xl md:text-6xl text-zinc-900 dark:text-white mb-4">Page not found</h1>
      <p class="text-zinc-500 dark:text-zinc-400 mb-8 max-w-sm mx-auto">The page you're looking for doesn't exist or has been moved.</p>
      <a href={base} class="inline-flex items-center gap-2 bg-accent text-white font-medium px-7 py-3.5 rounded-full hover:bg-accent-light transition-colors text-sm">
        Back to home
      </a>
    </div>
  </main>
</BaseLayout>
