---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Blog — Waseem Akram"
  description="Lessons from a decade of Android and Flutter development — architecture, patterns, and the things they don't teach you in bootcamp."
  canonicalUrl="https://waseemarain4u.github.io/my-portfolio/blog"
  ogImage="https://images.unsplash.com/photo-1607252650355-f7fd0460ccdb?w=1200&q=80"
  page="blog"
>
  <main class="pt-24">
    <section class="pt-12 pb-12 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-80 h-80 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <p class="text-xs font-medium text-accent tracking-widest uppercase mb-3">Thoughts</p>
        <h1 class="font-display font-bold text-5xl md:text-6xl text-zinc-900 dark:text-white leading-tight mb-4">From the Blog</h1>
        <p class="text-lg text-zinc-500 dark:text-zinc-400 max-w-xl leading-relaxed">Lessons from a decade of Android and Flutter development — architecture, patterns, and the things they don't teach you in bootcamp.</p>
      </div>
    </section>

    <section class="pb-24">
      <div class="max-w-6xl mx-auto px-6">

        <!-- Featured post -->
        <article class="group rounded-2xl overflow-hidden bg-zinc-50 dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors mb-6">
          <div class="grid md:grid-cols-2">
            <div class="pf w-full h-64 md:h-auto">
              <img src="https://images.unsplash.com/photo-1607252650355-f7fd0460ccdb?w=900&q=80" alt="Flutter architecture" loading="lazy">
            </div>
            <div class="p-8 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-xs bg-blue-50 dark:bg-zinc-800 text-accent border border-blue-200 dark:border-zinc-700 px-2.5 py-1 rounded-full">Flutter</span>
                <span class="text-xs text-zinc-400">May 10, 2025</span>
              </div>
              <a href={`${base}blog-article`}>
                <h2 class="font-display font-bold text-2xl text-zinc-900 dark:text-white mb-3 group-hover:text-accent transition-colors">Why I switched from MVC to Clean Architecture in Flutter</h2>
              </a>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-5">After shipping 5 apps with traditional MVC, here's what finally pushed me to restructure everything — and why my team will never go back.</p>
              <a href={`${base}blog-article`} class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-900 dark:text-white self-start">Read article →</a>
            </div>
          </div>
        </article>

        <div class="grid md:grid-cols-3 gap-6">
          {[
            { href: 'blog-article-why-flutter', img: 'https://miro.medium.com/v2/resize:fit:800/1*3-M8z7qtE32OgRGQEBSX-Q.png', alt: 'Why Flutter is Better', tag: 'Flutter', date: 'Jun 21, 2023', title: 'Why Flutter is better?', desc: '8 reasons why Flutter stands out as the best cross-platform framework — from single codebase to native performance and future-proofing.' },
            { href: 'blog-article-multi-display', img: 'https://images.unsplash.com/photo-1527443224154-c4a3942d3acf?w=700&q=80', alt: 'Multi-Display Android', tag: 'Android', date: 'Sep 5, 2023', title: 'Multi-Display Magic in Android: Sending Messages to a Second Screen', desc: "Android's multi-display API is underused and underrated. Here's how to launch activities on a secondary display and communicate between them." },
            { href: 'blog-article-star-rating', img: 'https://images.unsplash.com/photo-1618477388954-7852f32655ec?w=700&q=80', alt: 'Star Rating Widget Flutter', tag: 'Flutter', date: 'Aug 12, 2023', title: 'Building a Custom Interactive Star Rating Widget in Flutter', desc: 'A step-by-step guide to building a fully interactive, gesture-driven star rating widget from scratch — no packages required.' },
            { href: 'blog-article-kotlin', img: 'https://images.unsplash.com/photo-1555099962-4199c345e5dd?w=700&q=80', alt: 'Kotlin vs Java', tag: 'Android', date: 'Apr 3, 2025', title: 'Kotlin vs Java in 2025: when to still choose Java', desc: 'Kotlin is the default, but there are still real-world situations where Java makes more sense for your Android project.' },
            { href: 'blog-article-bloc', img: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=700&q=80', alt: 'Flutter state management', tag: 'Flutter', date: 'Feb 18, 2025', title: 'BLoC, Riverpod, or Provider? My honest take after 4 years', desc: "I've shipped Flutter apps with all three. Here's when each one is actually the right choice — no hype, just experience." },
            { href: 'blog-article-leadership', img: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=700&q=80', alt: 'Team leadership', tag: 'Leadership', date: 'Jan 7, 2025', title: 'What no one told me about leading a mobile dev team', desc: 'Technical skill gets you to senior. These things get you to lead. Lessons from running teams across three different companies.' },
            { href: 'blog-article-performance', img: 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=700&q=80', alt: 'Performance optimization', tag: 'Performance', date: 'Dec 2, 2024', title: "5 Flutter performance mistakes I made so you don't have to", desc: "Jank, memory leaks, unnecessary rebuilds — a tour of the performance issues I've debugged over the years and how to avoid them." },
            { href: 'blog-article-databases', img: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=700&q=80', alt: 'SQL databases', tag: 'Data', date: 'Nov 14, 2024', title: 'Local databases in Flutter: SQLite, Hive, or Drift?', desc: 'A practical comparison based on real production use — covering performance, query flexibility, and developer experience for offline-first apps.' },
            { href: 'blog-article-desktop', img: 'https://images.unsplash.com/photo-1593642532454-e138e28a63f4?w=700&q=80', alt: 'Cross platform', tag: 'Flutter', date: 'Oct 5, 2024', title: "Shipping Flutter to Desktop: what I wish I'd known", desc: 'Expanding a mobile Flutter app to Windows and macOS surfaces a whole new set of challenges. Here\'s what to expect and how to handle it.' },
          ].map(post => (
            <article class="group bg-white dark:bg-zinc-900 rounded-2xl overflow-hidden border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors">
              <div class="pf w-full h-44">
                <img src={post.img} alt={post.alt} loading="lazy">
              </div>
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-xs bg-blue-50 dark:bg-zinc-800 text-accent border border-blue-200 dark:border-zinc-700 px-2.5 py-1 rounded-full">{post.tag}</span>
                  <span class="text-xs text-zinc-400">{post.date}</span>
                </div>
                <a href={`${base}${post.href}`}>
                  <h3 class="font-display font-bold text-lg text-zinc-900 dark:text-white mb-2 group-hover:text-accent transition-colors">{post.title}</h3>
                </a>
                <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">{post.desc}</p>
                <a href={`${base}${post.href}`} class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-900 dark:text-white">Read more →</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
