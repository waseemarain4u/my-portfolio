---
import HomeLayout from '../layouts/HomeLayout.astro';
const base = import.meta.env.BASE_URL;
---

<HomeLayout
  title="Waseem Akram — Senior Flutter Developer & Lead Developer"
  description="Senior Flutter & Android developer with 10+ years experience. Cross-platform mobile apps for Android, iOS, Web and Desktop."
  canonicalUrl="https://waseemarain4u.github.io/my-portfolio/"
  ogImage="https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?w=1200&q=80"
>

<main>

<!-- HERO -->
<section id="hero" class="relative pt-16">
  <div class="relative z-10 max-w-6xl mx-auto px-6 py-24 w-full">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-sm font-medium text-accent tracking-widest uppercase mb-4">Available for new projects</p>
        <h1 class="font-display font-bold text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-zinc-900 dark:text-white mb-6">
          Hi, I'm <span class="text-accent">Waseem</span>
        </h1>
        <p class="text-lg md:text-xl text-zinc-500 dark:text-zinc-400 font-light leading-relaxed mb-10">
          <strong class="font-medium text-zinc-700 dark:text-zinc-300">Senior Flutter Developer &amp; Lead Developer</strong> — Flutter/Android | iOS | Desktop (Windows &amp; Mac) | Web. I architect scalable, high-performance apps with clean UI, efficient state management, and seamless backend integrations. Fast, beautiful, and built to last.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#work" class="inline-flex items-center gap-2 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 font-medium px-7 py-3.5 rounded-full hover:bg-zinc-700 dark:hover:bg-zinc-200 transition-colors text-sm">
            View my work
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
          <a href="#contact" class="inline-flex items-center gap-2 border border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 font-medium px-7 py-3.5 rounded-full hover:bg-zinc-50 dark:hover:bg-zinc-900 transition-colors text-sm">Get in touch</a>
        </div>
        <div class="flex gap-8 mt-14 pt-8 border-t border-zinc-100 dark:border-zinc-900">
          <div><p class="font-display font-bold text-3xl text-zinc-900 dark:text-white">15+</p><p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">Apps shipped</p></div>
          <div><p class="font-display font-bold text-3xl text-zinc-900 dark:text-white">10+</p><p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">Years experience</p></div>
          <div><p class="font-display font-bold text-3xl text-zinc-900 dark:text-white">6+</p><p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">Companies served</p></div>
        </div>
      </div>
      <div class="hidden md:flex justify-center items-center">
        <div class="relative w-64">
          <div class="relative bg-zinc-900 dark:bg-zinc-800 rounded-[2.5rem] p-3 shadow-2xl ring-1 ring-zinc-700">
            <div class="absolute top-3 left-1/2 -translate-x-1/2 w-20 h-5 bg-zinc-800 dark:bg-zinc-700 rounded-full z-10"></div>
            <div class="rounded-[2rem] overflow-hidden bg-white" style="height:500px">
              <img src="https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?w=600&q=80" alt="Flutter app" loading="eager" class="w-full h-full object-cover">
            </div>
          </div>
          <div class="absolute -right-8 top-14 bg-white dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-800 rounded-2xl px-4 py-3 shadow-lg flex items-center gap-2.5">
            <span class="w-8 h-8 bg-blue-500/10 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M14.314 0L2.3 12 6 15.7 21.684 0h-7.37zm.014 11.072L7.857 17.53l6.47 6.47H21.7l-6.46-6.468 6.46-6.46h-7.37z"/></svg>
            </span>
            <div>
              <p class="text-xs font-bold text-zinc-900 dark:text-white">Flutter</p>
              <p class="text-xs text-zinc-400">Cross-platform</p>
            </div>
          </div>
          <div class="absolute -left-8 bottom-20 bg-white dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-800 rounded-2xl px-4 py-3 shadow-lg">
            <p class="text-xs font-bold text-zinc-900 dark:text-white mb-0.5">15+ Apps</p>
            <p class="text-xs text-zinc-400">Shipped to production</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SKILLS -->
<section id="services" class="py-24 bg-zinc-50 dark:bg-zinc-900/40">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-14">
      <p class="text-xs font-medium text-accent tracking-widest uppercase mb-3">What I do</p>
      <h2 class="font-display font-bold text-4xl md:text-5xl text-zinc-900 dark:text-white">Core Skills</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <article class="group bg-white dark:bg-zinc-900 rounded-2xl p-8 border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors">
        <div class="w-12 h-12 flex items-center justify-center bg-blue-50 dark:bg-zinc-800 rounded-xl mb-6 group-hover:bg-accent/10 transition-colors">
          <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
        </div>
        <h3 class="font-display font-bold text-xl text-zinc-900 dark:text-white mb-3">Flutter Development</h3>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">Cross-platform apps for Android, iOS, Web, and Desktop from a single codebase. Clean architecture, state management, and pixel-perfect UIs that feel truly native on every platform.</p>
      </article>
      <article class="group bg-white dark:bg-zinc-900 rounded-2xl p-8 border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors">
        <div class="w-12 h-12 flex items-center justify-center bg-blue-50 dark:bg-zinc-800 rounded-xl mb-6 group-hover:bg-accent/10 transition-colors">
          <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
        </div>
        <h3 class="font-display font-bold text-xl text-zinc-900 dark:text-white mb-3">Android (Java / Kotlin)</h3>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">Native Android apps with Kotlin and Java. From architectural decisions to Play Store delivery — including complex integrations, background services, and performance-critical features.</p>
      </article>
      <article class="group bg-white dark:bg-zinc-900 rounded-2xl p-8 border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors">
        <div class="w-12 h-12 flex items-center justify-center bg-blue-50 dark:bg-zinc-800 rounded-xl mb-6 group-hover:bg-accent/10 transition-colors">
          <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <h3 class="font-display font-bold text-xl text-zinc-900 dark:text-white mb-3">Team Leadership</h3>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">Leading and mentoring mobile dev teams, collaborating with stakeholders, and driving agile delivery. I translate product requirements into reliable, maintainable engineering outcomes.</p>
      </article>
    </div>
  </div>
</section>

<!-- WORK -->
<section id="work" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-14">
      <div>
        <p class="text-xs font-medium text-accent tracking-widest uppercase mb-3">Portfolio</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-zinc-900 dark:text-white">Selected Work</h2>
      </div>
      <a href={`${base}projects`} class="text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-accent transition-colors self-start sm:self-auto">All projects &rarr;</a>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <article class="group rounded-2xl overflow-hidden bg-zinc-100 dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors md:row-span-2">
        <div class="pf w-full h-64 md:h-80">
          <img src="https://images.unsplash.com/photo-1563986768494-4dee2763ff3f?w=900&q=80" alt="AI Content Master" loading="lazy">
        </div>
        <div class="p-7">
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs bg-blue-50 dark:bg-zinc-800 text-accent border border-blue-200 dark:border-zinc-700 px-3 py-1 rounded-full">Flutter</span>
            <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">AI</span>
            <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">Cross-platform</span>
          </div>
          <h3 class="font-display font-bold text-2xl text-zinc-900 dark:text-white mb-2">AI Content Master</h3>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">A cross-platform AI-powered content generation app built with Flutter. Delivers a seamless experience on Android, iOS, and Web from a single codebase. Features intelligent writing assistance, rich text editing, and cloud sync across devices.</p>
        </div>
      </article>
      <article class="group rounded-2xl overflow-hidden bg-zinc-100 dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors">
        <div class="pf w-full h-48">
          <img src="https://images.unsplash.com/photo-1601784551446-20c9e07cdbdb?w=800&q=80" alt="MyCart E-commerce App" loading="lazy">
        </div>
        <div class="p-6">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="text-xs bg-blue-50 dark:bg-zinc-800 text-accent border border-blue-200 dark:border-zinc-700 px-3 py-1 rounded-full">Android</span>
            <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">E-commerce</span>
          </div>
          <h3 class="font-display font-bold text-xl text-zinc-900 dark:text-white mb-1.5">MyCart — E-commerce Suite</h3>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">Consumer app, inventory management, rider app, and employee apps — a complete e-commerce ecosystem built in native Android for a growing retail brand.</p>
        </div>
      </article>
      <article class="group rounded-2xl overflow-hidden bg-zinc-100 dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors">
        <div class="pf w-full h-48">
          <img src="https://images.unsplash.com/photo-1512428559087-560fa5ceab42?w=800&q=80" alt="GetVPN App" loading="lazy">
        </div>
        <div class="p-6">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="text-xs bg-blue-50 dark:bg-zinc-800 text-accent border border-blue-200 dark:border-zinc-700 px-3 py-1 rounded-full">Flutter</span>
            <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">Security</span>
          </div>
          <h3 class="font-display font-bold text-xl text-zinc-900 dark:text-white mb-1.5">GetVPN — Security App</h3>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">Cross-platform VPN client built with Flutter, supporting Android and iOS with a focus on performance, reliability, and an intuitive one-tap connection experience.</p>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- BLOG -->
<section id="blog" class="py-24 bg-zinc-50 dark:bg-zinc-900/40">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-14">
      <div>
        <p class="text-xs font-medium text-accent tracking-widest uppercase mb-3">Writing</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-zinc-900 dark:text-white">From the Blog</h2>
      </div>
      <a href={`${base}blog`} class="text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-accent transition-colors self-start sm:self-auto">All articles &rarr;</a>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <article class="group bg-white dark:bg-zinc-900 rounded-2xl overflow-hidden border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors">
        <div class="pf w-full h-44"><img src="https://images.unsplash.com/photo-1607252650355-f7fd0460ccdb?w=700&q=80" alt="Clean Architecture" loading="lazy"></div>
        <div class="p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs bg-blue-50 dark:bg-zinc-800 text-accent border border-blue-200 dark:border-zinc-700 px-2.5 py-1 rounded-full">Flutter</span>
            <span class="text-xs text-zinc-400">May 10, 2025</span>
          </div>
          <a href={`${base}blog-article`}><h3 class="font-display font-bold text-lg text-zinc-900 dark:text-white mb-2 group-hover:text-accent transition-colors">Why I switched from MVC to Clean Architecture in Flutter</h3></a>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">After shipping 5 apps with traditional MVC, here's what finally pushed me to restructure everything.</p>
          <a href={`${base}blog-article`} class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-900 dark:text-white">Read more &rarr;</a>
        </div>
      </article>
      <article class="group bg-white dark:bg-zinc-900 rounded-2xl overflow-hidden border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors">
        <div class="pf w-full h-44"><img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=700&q=80" alt="State management" loading="lazy"></div>
        <div class="p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs bg-blue-50 dark:bg-zinc-800 text-accent border border-blue-200 dark:border-zinc-700 px-2.5 py-1 rounded-full">Flutter</span>
            <span class="text-xs text-zinc-400">Feb 18, 2025</span>
          </div>
          <a href={`${base}blog-article-bloc`}><h3 class="font-display font-bold text-lg text-zinc-900 dark:text-white mb-2 group-hover:text-accent transition-colors">BLoC, Riverpod, or Provider? My honest take after 4 years</h3></a>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">I've shipped Flutter apps with all three. Here's when each one is actually the right choice.</p>
          <a href={`${base}blog-article-bloc`} class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-900 dark:text-white">Read more &rarr;</a>
        </div>
      </article>
      <article class="group bg-white dark:bg-zinc-900 rounded-2xl overflow-hidden border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors">
        <div class="pf w-full h-44"><img src="https://miro.medium.com/v2/resize:fit:800/1*3-M8z7qtE32OgRGQEBSX-Q.png" alt="Why Flutter is Better" loading="lazy"></div>
        <div class="p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs bg-blue-50 dark:bg-zinc-800 text-accent border border-blue-200 dark:border-zinc-700 px-2.5 py-1 rounded-full">Flutter</span>
            <span class="text-xs text-zinc-400">Jun 21, 2023</span>
          </div>
          <a href={`${base}blog-article-why-flutter`}><h3 class="font-display font-bold text-lg text-zinc-900 dark:text-white mb-2 group-hover:text-accent transition-colors">Why Flutter is better?</h3></a>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">8 reasons why Flutter stands out — single codebase, native performance, rich UI, and why Google's backing matters.</p>
          <a href={`${base}blog-article-why-flutter`} class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-900 dark:text-white">Read more &rarr;</a>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section id="about" class="py-24 bg-zinc-50 dark:bg-zinc-900/40">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-xs font-medium text-accent tracking-widest uppercase mb-3">About me</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-zinc-900 dark:text-white mb-6">Diligent dev, team player</h2>
        <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">
          I'm Waseem Akram, a Senior Flutter Developer at Cronysoft with a strong focus on building scalable, high-performance mobile applications. I specialise in crafting clean UI architectures, efficient state management, and seamless integrations with backend services like Firebase, subscriptions, and payment systems.
        </p>
        <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">
          I enjoy turning complex requirements into simple, user-friendly solutions — whether it's optimising app performance, structuring robust data models, or designing intuitive user experiences.
        </p>
        <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed mb-8">
          Currently working on innovative products including a neuro-resilient therapy app, aiming to combine technology with meaningful user impact.
        </p>
        <div>
          <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-widest mb-3">Stack &amp; Tools</p>
          <div class="flex flex-wrap gap-2" role="list" aria-label="Skills">
            {['Flutter','Dart','Kotlin','Java','Android Studio','SQL','Firebase','REST APIs','Payment Integration','App Architecture','UI/UX Optimization'].map(skill => (
              <span role="listitem" class="text-sm bg-white dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 px-3.5 py-1.5 rounded-full hover:border-accent transition-colors">{skill}</span>
            ))}
          </div>
        </div>
      </div>
      <div class="flex flex-col gap-6">
        <div class="pf w-full rounded-2xl overflow-hidden" style="height:320px">
          <img src="https://images.unsplash.com/photo-1555099962-4199c345e5dd?w=800&q=80" alt="Flutter development" loading="lazy">
        </div>
        <div class="grid grid-cols-3 gap-px bg-zinc-200 dark:bg-zinc-800 rounded-2xl overflow-hidden">
          <div class="bg-white dark:bg-zinc-900 p-5 text-center">
            <p class="font-display font-bold text-2xl text-zinc-900 dark:text-white">15+</p>
            <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">Apps shipped</p>
          </div>
          <div class="bg-white dark:bg-zinc-900 p-5 text-center">
            <p class="font-display font-bold text-2xl text-zinc-900 dark:text-white">10+</p>
            <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">Years exp.</p>
          </div>
          <div class="bg-white dark:bg-zinc-900 p-5 text-center">
            <p class="font-display font-bold text-2xl text-zinc-900 dark:text-white">6+</p>
            <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">Companies</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- EXPERIENCE -->
<section id="experience" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-14">
      <p class="text-xs font-medium text-accent tracking-widest uppercase mb-3">Career</p>
      <h2 class="font-display font-bold text-4xl md:text-5xl text-zinc-900 dark:text-white">Experience</h2>
    </div>
    <div class="flex flex-col gap-10">
      {[
        { period: 'Dec 2023 — Present', role: 'Senior Flutter Developer', company: 'Cronysoft', desc: 'Leading cross-platform development for mobile, desktop, and web applications. Driving user-centric design decisions, collaborating directly with stakeholders, and mentoring junior developers to deliver high-quality products on schedule.' },
        { period: 'Jan 2020 — Nov 2023', role: 'Senior Mobile Application Developer', company: 'Codelabs', desc: 'Directed application development across multiple product lines. Researched and introduced new development methodologies to boost team efficiency, and mentored junior developers in best practices.' },
        { period: 'Jul 2019 — Dec 2019', role: 'Senior Developer', company: 'NxN Pakistan', desc: 'Developed, installed, and configured internal applications and managed new release deployments into test and production environments.' },
        { period: 'Jan 2016 — Jun 2019', role: 'Android Developer', company: 'MyCart', desc: 'Built an e-commerce consumer app, inventory management system, rider app, and employee applications — a complete mobile ecosystem supporting multiple operations departments.' },
        { period: 'Nov 2013 — Dec 2015', role: 'Android Developer', company: 'D4sys', desc: 'Participated in architectural decisions for mobile apps and supervised junior team members through code reviews and mentoring sessions.' },
        { period: 'Mar 2014 — Mar 2015 · Part Time', role: 'Android Developer', company: 'Technology Minds', desc: 'Developed various mobile applications in collaboration with peer developers. Implemented new controls and methods in native Android development as part of a team.' },
        { period: 'Mar 2013 — Sep 2013', role: 'Junior Android Developer', company: 'Aleedex', desc: 'Collaborated with the mobile team across different projects. Solved Android app development challenges including memory and performance issues.' },
      ].map(job => (
        <div class="grid md:grid-cols-2 gap-6 md:gap-12 items-start">
          <div class="md:text-right md:pr-12">
            <span class="inline-block text-xs font-medium text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 px-3 py-1 rounded-full mb-2">{job.period}</span>
            <h3 class="font-display font-bold text-xl text-zinc-900 dark:text-white">{job.role}</h3>
            <p class="text-sm text-zinc-500 dark:text-zinc-400">{job.company}</p>
          </div>
          <div class="md:pl-12">
            <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">{job.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CONTACT -->
<section id="contact" class="py-24 bg-zinc-50 dark:bg-zinc-900/40">
  <div class="max-w-6xl mx-auto px-6">
